# git
alias gl="git ll"
alias gs="git status"
alias pr="gh pr create"
alias gpu="git pull upstream master"
alias gpo="git pull origin master"

# docker/kubernetes
alias k="kubectl"
alias kl="kubectl login"
alias kns="kubens"
alias kc="kubectx"
alias docker-remove-containers="docker rm $(docker ps -a -f status=exited -q)"
alias docker-clean-unused="docker system prune --all --force --volumes"
alias docker-clean-all="docker stop $(docker container ls -a -q) && docker system prune -a -f --volumes"

# node/npm
alias ns="npm start"
alias nt="npm test"
alias nr="npm run"
alias nw="npm run test:watch"

# scala/sbt
alias sc="sbt compile"
