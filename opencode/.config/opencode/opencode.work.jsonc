{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "date *": "allow",
      "mkdir -p .opencode/sessions": "allow"
    },
    "external_directory": {
      "*": "ask",
      "/Users/jordan.fjellman/.config/opencode/**/*": "allow",
      "/Users/jordan.fjellman/notes/**/*.md": "allow"
    }
  },
  "provider": {
    "kiro": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:9111/v1",
        "headers": {
          "Authorization": "Bearer {file:~/.secrets/kiro-gateway-password}"
        }
      },
      "models": {
        "auto": {
          "name": "Auto"
        },
        "claude-opus-4.6": {
          "name": "Opus"
        },
        "claude-sonnet-4.6": {
          "name": "Sonnet"
        },
        "claude-haiku-4.5": {
          "name": "Haiku"
        }
      }
    }
  },
  "mcp": {
    "atlassian-mcp-server": {
      "enabled": true,
      "type": "local",
      "command": ["uvx", "mcp-atlassian"],
      "environment": {
        "JIRA_URL": "https://lifeway.atlassian.net",
        "JIRA_USERNAME": "{file:~/.secrets/opencode-atlassian-username}",
        "JIRA_API_TOKEN": "{file:~/.secrets/opencode-atlassian-api-key}",
        "CONFLUENCE_URL": "https://lifeway.atlassian.net/wiki",
        "CONFLUENCE_USERNAME": "{file:~/.secrets/opencode-atlassian-username}",
        "CONFLUENCE_API_TOKEN": "{file:~/.secrets/opencode-atlassian-api-key}"
      }
    },
    "expo-mcp": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.expo.dev/mcp",
      "oauth": {}
    },
    "figma": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {
        "clientId": "{file:~/.secrets/figma-client-id}",
        "clientSecret": "{file:~/.secrets/figma-client-secret}"
      }
    },
    "xlsx": {
      "enabled": false,
      "type": "local",
      "command": ["uvx", "excel-mcp-server", "stdio"],
      "environment": {}
    }
  //   "aws-core-mcp-server": {
