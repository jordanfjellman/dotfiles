  //       "public.ecr.aws/awslabs-mcp/awslabs/aws-api-mcp-server:latest",
  //     ],
  //     "environment": {},
  //   },
  //   "aws-knowledge-mcp-server": {
  //     "enabled": false,
  //     "type": "local",
  //     "command": ["npx", "mcp-remote", "https://knowledge-mcp.global.api.aws"],
  //   },
  }
}
