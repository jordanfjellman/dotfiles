{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["~/notes/LLM Context/AGENTS.md"],
  "permission": {
    "bash": {
      "date *": "allow",
      "mkdir -p .opencode/sessions": "allow"
    },
    "external_directory": {
      "*": "ask",
      "/Users/jordan/.config/opencode/**/*": "allow",
      "/Users/jordan/notes/**/*.md": "allow"
    }
  },
  "mcp": {
    "brave-search": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "@brave/brave-search-mcp-server"],
      "environment": {
        "BRAVE_API_KEY": "{file:~/.secrets/opencode-brave-api-key}"
      }
    }
