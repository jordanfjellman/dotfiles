#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
  selected=$1
elif [[ ! -t 0 ]]; then
  read selected
else
  echo "Usage: tmux-sessionizer <session name>"
  exit 0
fi

if [[ -z $selected ]]; then
  exit 0
fi

# Name the session after the path. For bare-repo worktrees, a plain
# basename collides (myrepo/feature-x and other/feature-x both -> feature-x),
# so when the parent dir is a bare-repo root (has a .bare sibling) we use
# repo/branch instead.
if [[ -d "$(dirname "$selected")/.bare" ]]; then
  selected_name=$(basename "$(dirname "$selected")")/$(basename "$selected")
else
  selected_name=$(basename "$selected")
fi
selected_name=$(echo "$selected_name" | tr ' .' '_')
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
  tmux new-session -s "$selected_name" -c "$selected"
  exit 0
fi

if ! tmux has-session -t $selected_name 2> /dev/null; then
  tmux new-session -ds $selected_name -c "$selected"
fi

if [[ -z $TMUX ]]; then
  tmux attach-session -t $selected_name
else
  tmux switch-client -t $selected_name
fi

