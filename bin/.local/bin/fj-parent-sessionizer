#!/usr/bin/env bash
# Launch (or reattach to) the fjellyspaces parent agent session.
#
# Creates a dedicated tmux session running opencode configured to act
# as the parent orchestrator for fjellyspaces workspaces. Uses a cheap
# model by default to minimize cost.
#
# If the session already exists, just switches to it.
#
# Usage:
#   fj-parent-sessionizer              # default model (sonnet)
#   FJ_PARENT_MODEL=kiro/auto fj-parent-sessionizer  # override model

set -euo pipefail

SESSION_NAME="fj-parent"
MODEL="${FJ_PARENT_MODEL:-kiro/claude-sonnet-4.6}"

# Ensure daemon is running (suppress output if already running)
fj daemon start 2>/dev/null || true

# If session already exists, just switch/attach
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    if [[ -z "${TMUX:-}" ]]; then
        exec tmux attach-session -t "$SESSION_NAME"
    else
        exec tmux switch-client -t "$SESSION_NAME"
    fi
fi

# Create new session running opencode with the parent agent model
tmux new-session -ds "$SESSION_NAME" -c "$HOME" \
    "opencode --model $MODEL"

if [[ -z "${TMUX:-}" ]]; then
    exec tmux attach-session -t "$SESSION_NAME"
else
    exec tmux switch-client -t "$SESSION_NAME"
fi
